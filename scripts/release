#!/bin/sh
# Release script for memory-rlm
# Usage: ./scripts/release 0.3.0
#
# What it does:
#   1. Bumps version in Cargo.toml, plugin.json, and marketplace.json
#   2. Commits and tags memory-rlm, pushes (triggers CI → builds binaries)
#   3. Commits and pushes claude-plugins marketplace update
#
# Prerequisites:
#   - Clean working trees in both repos
#   - MARKETPLACE_REPO env var or ../rlm/claude-plugins relative to this repo
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Marketplace repo: check env var, then common locations
if [ -n "$MARKETPLACE_REPO" ]; then
    MARKETPLACE="$MARKETPLACE_REPO"
elif [ -d "$REPO_ROOT/../rlm/claude-plugins" ]; then
    MARKETPLACE="$(cd "$REPO_ROOT/../rlm/claude-plugins" && pwd)"
elif [ -d "$REPO_ROOT/../claude-plugins" ]; then
    MARKETPLACE="$(cd "$REPO_ROOT/../claude-plugins" && pwd)"
else
    echo "ERROR: Cannot find claude-plugins repo."
    echo "Set MARKETPLACE_REPO=/path/to/claude-plugins or place it next to memory-rlm."
    exit 1
fi

MARKETPLACE_JSON="$MARKETPLACE/.claude-plugin/marketplace.json"

if [ -z "$1" ]; then
    # Show current version
    current="$(grep '^version' "$REPO_ROOT/Cargo.toml" | head -1 | sed 's/.*"\(.*\)".*/\1/')"
    echo "Current version: $current"
    echo "Usage: $0 <new-version>  (e.g. $0 0.3.0)"
    exit 1
fi

NEW_VERSION="$1"
TAG="v${NEW_VERSION}"

info()  { printf "\033[1;34m==> %s\033[0m\n" "$*"; }
ok()    { printf "\033[1;32m==> %s\033[0m\n" "$*"; }
err()   { printf "\033[1;31m==> %s\033[0m\n" "$*"; exit 1; }

# Sanity checks
cd "$REPO_ROOT"
if [ -n "$(git status --porcelain)" ]; then
    err "memory-rlm has uncommitted changes. Commit or stash first."
fi

cd "$MARKETPLACE"
if [ -n "$(git status --porcelain)" ]; then
    err "claude-plugins has uncommitted changes. Commit or stash first."
fi

if ! [ -f "$MARKETPLACE_JSON" ]; then
    err "marketplace.json not found at $MARKETPLACE_JSON"
fi

# Check tag doesn't already exist
cd "$REPO_ROOT"
if git rev-parse "$TAG" >/dev/null 2>&1; then
    err "Tag $TAG already exists in memory-rlm."
fi

# --- Step 1: Bump memory-rlm versions ---
info "Bumping memory-rlm to $NEW_VERSION..."

# Cargo.toml — first version = line only
sed -i "0,/^version = /s/^version = \".*\"/version = \"$NEW_VERSION\"/" "$REPO_ROOT/Cargo.toml"

# .claude-plugin/plugin.json
sed -i "s/\"version\": \"[^\"]*\"/\"version\": \"$NEW_VERSION\"/" "$REPO_ROOT/.claude-plugin/plugin.json"

# Verify
cargo_ver="$(grep '^version' "$REPO_ROOT/Cargo.toml" | head -1)"
plugin_ver="$(grep '"version"' "$REPO_ROOT/.claude-plugin/plugin.json")"
info "  Cargo.toml:  $cargo_ver"
info "  plugin.json: $plugin_ver"

# --- Step 2: Commit, tag, push memory-rlm ---
info "Committing and tagging memory-rlm..."
cd "$REPO_ROOT"
git add Cargo.toml .claude-plugin/plugin.json
git commit -m "Release $TAG"
git tag "$TAG"
git push origin main "$TAG"
ok "Pushed memory-rlm $TAG — CI will build binaries"

# --- Step 3: Update marketplace ---
info "Updating claude-plugins marketplace..."

# Update only the memory-rlm version, preserving other plugins in the file.
# Matches the "memory-rlm" name line, sets a flag, then updates the first
# subsequent "version" line.
sed -i '/"name": "memory-rlm"/,/"version":/{s/"version": "[^"]*"/"version": "'"$NEW_VERSION"'"/}' "$MARKETPLACE_JSON"

cd "$MARKETPLACE"
git add .claude-plugin/marketplace.json
git commit -m "Update memory-rlm to $TAG"
git push origin main
ok "Pushed marketplace update"

# --- Done ---
echo ""
ok "Release $TAG complete!"
echo ""
echo "  CI build:  https://github.com/dullfig/memory-rlm/actions"
echo "  Release:   https://github.com/dullfig/memory-rlm/releases/tag/$TAG"
echo ""
echo "  Once CI finishes, users get the new version on next /plugin install."
echo ""
